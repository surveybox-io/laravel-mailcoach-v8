{
    "name": "spatie/laravel-mailcoach",
    "description": "Send email campaigns using Laravel",
    "keywords": [
        "spatie",
        "laravel-mailcoach",
        "mail",
        "mass mailing"
    ],
    "homepage": "https://mailcoach.app",
    "authors": [
        {
            "name": "Freek Van der Herten",
            "email": "freek@spatie.be",
            "homepage": "https://spatie.be",
            "role": "Developer"
        }
    ],
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require": {
        "php": "^8.3",
        "ext-dom": "*",
        "ext-libxml": "*",
        "ext-zip": "*",
        "aws/aws-php-sns-message-validator": "^1.7",
        "aws/aws-sdk-php": "^3.282",
        "filament/support": "^v3.0",
        "filament/tables": "^v3.0",
        "guzzlehttp/guzzle": "^7.0",
        "illuminate/auth": "^10.0|^11.9.2|^12.0",
        "illuminate/database": "^10.0|^11.9.2|^12.0",
        "illuminate/events": "^10.0|^11.9.2|^12.0",
        "illuminate/mail": "^10.0|^11.9.2|^12.0",
        "illuminate/queue": "^10.0|^11.9.2|^12.0",
        "illuminate/redis": "^10.0|^11.9.2|^12.0",
        "illuminate/support": "^10.0|^11.9.2|^12.0",
        "laravel/horizon": "^5.0",
        "laravel/pennant": "^1.11",
        "league/html-to-markdown": "^4.10|^5.0",
        "livewire/livewire": "^v3.6.4",
        "resend/resend-php": "^v0.15.1",
        "scrivo/highlight.php": "^9.18",
        "spatie/laravel-collection-macros": "^7.11|^8.0",
        "spatie/laravel-feed": "^4.0",
        "spatie/laravel-livewire-wizard": "^2.0",
        "spatie/laravel-markdown": "^2.2",
        "spatie/laravel-medialibrary": "^10.0.1|^11.0",
        "spatie/laravel-navigation": "^1.1",
        "spatie/laravel-package-tools": "^1.10.0",
        "spatie/laravel-query-builder": "^5.0|^6.0",
        "spatie/laravel-rate-limited-job-middleware": "^2.7.0",
        "spatie/laravel-schemaless-attributes": "^2.0",
        "spatie/laravel-validation-rules": "^3.0",
        "spatie/laravel-webhook-client": "^3.0",
        "spatie/laravel-webhook-server": "^3.2",
        "spatie/livewire-filepond": "^1.0",
        "spatie/mjml-php": "^1.0",
        "spatie/once": "^3.1",
        "spatie/simple-excel": "^2.1|^3.0",
        "spatie/temporary-directory": "^2.0",
        "symfony/amazon-mailer": "^6.3|^7.0",
        "symfony/brevo-mailer": "^7.0",
        "symfony/dom-crawler": "^6.0|^7.0",
        "symfony/http-client": "^6.0|^7.0",
        "symfony/mailgun-mailer": "^6.0|^7.0",
        "symfony/postmark-mailer": "^6.3|^7.0",
        "symfony/sendgrid-mailer": "^6.1|^7.0",
        "tempest/highlight": "^1.0|^2.0",
        "tijsverkoyen/css-to-inline-styles": "^2.2",
        "tpetry/laravel-query-expressions": "^1.4",
        "twig/twig": "^3.4"
    },
    "require-dev": {
        "fakerphp/faker": "^1.9",
        "laravel/framework": "^10.0|^11.9.2|^12.0",
        "laravel/pint": "^1.16",
        "laravel/sanctum": "^3.3|^v4.0",
        "nunomaduro/collision": "^7.0|^8.0",
        "larastan/larastan": "^2.0|^3.1",
        "orchestra/testbench": "^8.8|^9.0|^10.0",
        "pestphp/pest": "^3.7",
        "spatie/laravel-ray": "^1.27",
        "spatie/test-time": "^1.3"
    },
    "autoload": {
        "psr-4": {
            "Spatie\\Mailcoach\\": "src",
            "Spatie\\Mailcoach\\Database\\Factories\\": "database/factories"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Spatie\\Mailcoach\\Tests\\": "tests"
        }
    },
    "scripts": {
        "analyse": "vendor/bin/phpstan analyse --memory-limit=2G",
        "baseline": "vendor/bin/phpstan analyse --generate-baseline --memory-limit=2G",
        "format": "./vendor/bin/pint",
        "test": "./vendor/bin/pest --compact",
        "test-coverage": "vendor/bin/phpunit --coverage-html coverage",
        "split": "./split.sh"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "composer/package-versions-deprecated": true,
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Spatie\\Mailcoach\\MailcoachServiceProvider"
            ]
        }
    }
}
